# Copy this file to .env.local and fill in real values.
# Never commit .env.local or any file containing real secrets.

# --- Google OAuth (from Google Cloud Console > APIs & Services > Credentials) ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# --- Auth.js / NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-random-32-byte-secret
NEXTAUTH_URL=http://localhost:3000

# --- Gmail scanning ---
# Maximum number of messages a single scan retrieves from Gmail. Keep this
# low during local development so you don't scan an entire large mailbox.
GMAIL_SCAN_LIMIT=200

# --- Development safeguard ---
# When true, the app uses realistic mock senders instead of calling Gmail,
# so the UI can be built/tested without connecting a real Google account.
NEXT_PUBLIC_USE_MOCK_DATA=false
